[Unit]
Description=PennyPal OCR 服务 (RapidOCR, 仅本机)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Repository/PennyPal
ExecStart=/root/.local/share/mamba/envs/PennyPal/bin/uvicorn ocr_service.server:app --host 127.0.0.1 --port 8001 --app-dir /root/Repository/PennyPal
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
